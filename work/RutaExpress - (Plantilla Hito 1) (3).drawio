        <mxCell id="tbx-hline6" edge="1" parent="tobe-grp" style="endArrow=none;html=1;rounded=0;strokeColor=#BBBBBB;" value="">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="90" y="1480" as="sourcePoint" />
