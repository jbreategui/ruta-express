          <mxGeometry height="28" width="650" x="30" y="60" as="geometry" />
        </mxCell>
        <mxCell id="r4W5p9vPGWQqTcUIwUmc-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=14;arcSize=8;fillColor=#ffffff;strokeColor=#000000;spacing=8;" value="&lt;b&gt;Epica 1 - Gestión confiable de órdenes e inventario&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Requisitos Funcionales&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;RF-1.1 Unificación de estados&lt;/b&gt;&lt;div&gt;&lt;b&gt;Como &lt;/b&gt;&lt;span data-start=&quot;1819&quot; data-end=&quot;1840&quot; style=&quot;&quot;&gt;sistema logístico&lt;/span&gt;,&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;quiero &lt;/b&gt;&lt;span data-start=&quot;1849&quot; data-end=&quot;1925&quot; style=&quot;&quot;&gt;mantener un modelo unificado de estados para todas las etapas del pedido&lt;/span&gt;,&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;para &lt;/b&gt;&lt;span data-start=&quot;1932&quot; data-end=&quot;2000&quot; style=&quot;&quot;&gt;garantizar información consistente entre los diferentes sistemas&lt;/span&gt;.&lt;br&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;RF-1.2 Validar órdenes de ingreso&lt;/b&gt;&lt;br&gt;&lt;b&gt;Como &lt;/b&gt;sistema de gestión de órdenes,&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;quiero &lt;/b&gt;validar direccion, SKU, SLA, ventana, prioridad e idempotencia por cliente/canal/orden&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;para&amp;nbsp;&lt;/b&gt;&lt;span data-start=&quot;959&quot; data-end=&quot;1021&quot; style=&quot;&quot;&gt;evitar que información inválida ingrese al flujo logístico&lt;/span&gt;.&lt;br&gt;&lt;br&gt;&lt;b&gt;Requisitos No Funcionales&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;RNF-1.1 Consistencia de datos&lt;/b&gt;&lt;br&gt;&lt;b&gt;Como &lt;/b&gt;&lt;span data-start=&quot;5655&quot; data-end=&quot;5679&quot; style=&quot;&quot;&gt;responsable de datos&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;quiero &lt;/b&gt;&lt;span data-start=&quot;5687&quot; data-end=&quot;5802&quot; style=&quot;&quot;&gt;que cada cambio de estado incluya un identificador de correlación, fecha, sistema de origen y número de versión&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;para &lt;/b&gt;&lt;span data-start=&quot;5808&quot; data-end=&quot;5892&quot; style=&quot;&quot;&gt;detectar duplicados, mensajes fuera de orden e inconsistencias entre plataformas&lt;/span&gt;.&lt;/div&gt;" vertex="1">
          <mxGeometry height="550" width="355" x="30" y="100" as="geometry" />
        </mxCell>
        <mxCell id="r4W5p9vPGWQqTcUIwUmc-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=14;arcSize=8;fillColor=#ffffff;strokeColor=#000000;spacing=8;" value="&lt;b&gt;Épica 2 - Orquestación resiliente del despacho y la entrega&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Requisitos Funcionales&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;RF-2.1 Optimización de rutas&lt;/b&gt;&lt;br&gt;&lt;b&gt;Como &lt;/b&gt;&lt;span data-start=&quot;1831&quot; data-end=&quot;1861&quot; style=&quot;&quot;&gt;planificador de transporte&lt;/span&gt;&amp;nbsp;&lt;div&gt;&lt;b&gt;quiero &lt;/b&gt;&lt;span data-start=&quot;1869&quot; data-end=&quot;1927&quot; style=&quot;&quot;&gt;despachar únicamente pedidos con inventario confirmado&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;para &lt;/b&gt;&lt;span data-start=&quot;1933&quot; data-end=&quot;1990&quot; style=&quot;&quot;&gt;generar rutas completas y evitar entregas incompletas&lt;/span&gt;.&lt;br&gt;&lt;br&gt;&lt;b&gt;RF-2.2 Priorización pedidos críticos&lt;/b&gt;&lt;br&gt;&lt;b&gt;Como &lt;/b&gt;&lt;span data-start=&quot;600&quot; data-end=&quot;622&quot; style=&quot;&quot;&gt;operador logístico&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;quiero &lt;/b&gt;&lt;span data-start=&quot;630&quot; data-end=&quot;687&quot; style=&quot;&quot;&gt;priorizar los pedidos según cliente, SLA y criticidad&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;para &lt;/b&gt;&lt;span data-start=&quot;693&quot; data-end=&quot;781&quot; style=&quot;&quot;&gt;proteger el cumplimiento de las promesas de entrega durante periodos de alta demanda&lt;/span&gt;.&lt;div&gt;&lt;br&gt;&lt;b&gt;Requisitos No Funcionales&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;RNF-2.1 Alta Disponibilidad&lt;/b&gt;&lt;div&gt;&lt;b&gt;Como &lt;/b&gt;&lt;span data-start=&quot;6037&quot; data-end=&quot;6070&quot; style=&quot;&quot;&gt;responsable de operaciones TI&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;quiero &lt;/b&gt;&lt;span data-start=&quot;6078&quot; data-end=&quot;6169&quot; style=&quot;&quot;&gt;que los sistemas críticos alcancen una disponibilidad mínima del 99.9% durante campañas&lt;/span&gt; &lt;b&gt;para &lt;/b&gt;&lt;span data-start=&quot;6175&quot; data-end=&quot;6228&quot; style=&quot;&quot;&gt;mantener la continuidad de la operación logística&lt;/span&gt;.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;RNF-2.2 Escalabilidad&lt;/b&gt;&lt;div&gt;&lt;b&gt;Como &lt;/b&gt;&lt;span data-start=&quot;6297&quot; data-end=&quot;6330&quot; style=&quot;&quot;&gt;responsable de operaciones TI&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;quiero &lt;/b&gt;&lt;span data-start=&quot;6338&quot; data-end=&quot;6460&quot; style=&quot;&quot;&gt;que la plataforma soporte al menos 180,000 órdenes diarias y escale ante incrementos de demanda sin pérdida de pedidos&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;para &lt;/b&gt;&lt;span data-start=&quot;6466&quot; data-end=&quot;6499&quot; style=&quot;&quot;&gt;absorber los picos de campaña.&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="620" width="355" x="490" y="90" as="geometry" />
        </mxCell>
        <mxCell id="r4W5p9vPGWQqTcUIwUmc-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=14;arcSize=8;fillColor=#ffffff;strokeColor=#000000;spacing=8;" value="&lt;b&gt;Epica 3 - Trazabilidad y gestión de excepciones&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Requisitos Funcionales&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;RF-3.1 Gestionar excepciones estandarizadas&lt;/b&gt;&lt;br&gt;&lt;b&gt;Como &lt;/b&gt;&lt;span data-start=&quot;2772&quot; data-end=&quot;2785&quot; style=&quot;&quot;&gt;conductor&lt;/span&gt;&amp;nbsp;&lt;div&gt;&lt;b&gt;quiero &lt;/b&gt;&lt;span data-start=&quot;2793&quot; data-end=&quot;2865&quot; style=&quot;&quot;&gt;registrar las incidencias utilizando una clasificación estandarizada (motivos, reintentos y devoluciones)&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;para &lt;/b&gt;&lt;span data-start=&quot;2871&quot; data-end=&quot;2916&quot; style=&quot;&quot;&gt;facilitar su gestión y análisis posterior&lt;/span&gt;.&lt;br&gt;&lt;br&gt;&lt;b&gt;RF-3.2&amp;nbsp;Conservar y sincronizar evidencias de entrega&lt;/b&gt;&lt;br&gt;&lt;b&gt;Como &lt;/b&gt;&lt;span data-start=&quot;5120&quot; data-end=&quot;5133&quot; style=&quot;&quot;&gt;conductor&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;quiero &lt;/b&gt;&lt;span data-start=&quot;5141&quot; data-end=&quot;5279&quot; style=&quot;&quot;&gt;conservar de forma segura las firmas, fotografías, ubicaciones y eventos cuando no tenga conectividad, y sincronizarlos posteriormente&lt;/span&gt; &lt;b&gt;para &lt;/b&gt;&lt;span data-start=&quot;5285&quot; data-end=&quot;5366&quot; style=&quot;&quot;&gt;evitar la pérdida de evidencias necesarias para la trazabilidad y liquidación&lt;/span&gt;.&lt;br&gt;&lt;br&gt;&lt;b&gt;Requisitos No Funcionales&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;RNF-3.1 Trazabilidad end-to-end&lt;/b&gt;&lt;br&gt;&lt;b&gt;Como &lt;/b&gt;&lt;span data-start=&quot;3264&quot; data-end=&quot;3290&quot; style=&quot;&quot;&gt;auditor de operaciones&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;quiero &lt;/b&gt;&lt;span data-start=&quot;3298&quot; data-end=&quot;3379&quot; style=&quot;&quot;&gt;contar con trazabilidad completa de cada pedido durante todo su ciclo de vida&lt;/span&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;para &lt;/b&gt;&lt;span data-start=&quot;3385&quot; data-end=&quot;3441&quot; style=&quot;&quot;&gt;facilitar auditorías y resolver reclamos de clientes&lt;/span&gt;.&lt;/div&gt;" vertex="1">
          <mxGeometry height="550" width="355" x="910" y="90" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
