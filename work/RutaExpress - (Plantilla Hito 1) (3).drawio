        <mxCell id="FmO5tDaoR1T_aIih8wo7-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;ADM - E. Opportunities and Solutions&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="720" x="280" y="10" as="geometry" />
        </mxCell>
        <mxCell id="yc1NuJhD7JIQEAd6uZoT-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;" value="&lt;div&gt;&lt;b&gt;UTEC Posgrado - Programa en Arquitectura de Soluciones Multinube&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Módulo: &lt;/b&gt;Fundamentos de Arquitectura Empresarial&lt;/div&gt;&lt;b&gt;Elaborado por: &lt;/b&gt;Grupo 6 — RutaExpress&lt;div&gt;&lt;b&gt;Fecha: &lt;/b&gt;Junio 2026&lt;/div&gt;" vertex="1">
          <mxGeometry height="75" width="407.75" x="150" y="720" as="geometry" />
        </mxCell>
        <mxCell id="U2_1jExU0mF8jxLVTO_7-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontColor=#FF8000;" value="&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;font style=&quot;color: rgb(0, 204, 0);&quot;&gt;- Evolucionar Orquestador a un OMS centralizado para gestionar el ciclo de vida de las órdenes.&lt;/font&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;font style=&quot;background-color: transparent; color: light-dark(rgb(255, 128, 0), rgb(206, 97, 0));&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(255, 128, 0), rgb(206, 97, 0));&quot;&gt;Implementar validación, deduplicación e idempotencia de pedidos.&lt;/span&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Crear una vista unificada del inventario por SKU, almacén, ubicación, lote y estado.&lt;/span&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Integrar reservas, liberaciones y movimientos entre OMS, WMS, TMS y ERP.&lt;/span&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Conciliar conflictos de inventario entre el WMS central y los almacenes locales.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="187.5" width="330" x="160" y="183.75" as="geometry" />
        </mxCell>
        <mxCell id="U2_1jExU0mF8jxLVTO_7-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;" value="&lt;b&gt;Iniciativa:&amp;nbsp;&lt;/b&gt;Gestión unificada de órdenes e inventario end-to-end&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="40" width="310" x="160" y="130" as="geometry" />
        </mxCell>
        <mxCell id="U2_1jExU0mF8jxLVTO_7-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=center;" value="&lt;b&gt;Iniciativa:&amp;nbsp;&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Integración API-First y Event-Driven&lt;/span&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="40" width="260" x="520" y="130" as="geometry" />
        </mxCell>
        <mxCell id="U2_1jExU0mF8jxLVTO_7-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontColor=#FF8000;" value="&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;font style=&quot;color: rgb(0, 204, 0);&quot;&gt;&lt;font style=&quot;&quot;&gt;-&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Implementar una capa central de gestión y gobierno de APIs.&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Incorporar una plataforma de mensajería y eventos entre OMS, WMS, TMS, app, ERP y portal.&lt;/span&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Reemplazar progresivamente las integraciones punto a punto.&lt;/span&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Definir contratos estandarizados de APIs, eventos y modelos de datos.&lt;/span&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: rgb(0, 204, 0);&quot;&gt;- Incorporar colas, reintentos, priorización, backpressure y manejo de mensajes fallidos.&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="192.5" width="330" x="520" y="178.75" as="geometry" />
        </mxCell>
        <mxCell id="U2_1jExU0mF8jxLVTO_7-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=center;" value="&lt;b&gt;Iniciativa:&amp;nbsp;&lt;/b&gt;Optimización dinámica de rutas y despacho&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="40" width="260" x="160" y="400" as="geometry" />
        </mxCell>
        <mxCell id="U2_1jExU0mF8jxLVTO_7-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontColor=#FF8000;" value="&lt;span style=&quot;background-color: transparent;&quot;&gt;- Evolucionar el optimizador actual hacia una planificación dinámica.&lt;/span&gt;&lt;br&gt;&lt;font style=&quot;color: light-dark(rgb(0, 153, 0), rgb(0, 153, 0));&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Integrar tráfico, capacidad vehicular, ventanas horarias, cadena de frío, seguridad y SLA.&lt;/span&gt;&lt;br&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Integrar el optimizador con el TMS mediante APIs y eventos.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Automatizar la asignación de vehículos, conductores y paquetes.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Registrar y controlar los cambios manuales de rutas.&lt;/span&gt;" vertex="1">
          <mxGeometry height="142.5" width="330" x="160" y="455" as="geometry" />
        </mxCell>
        <mxCell id="U2_1jExU0mF8jxLVTO_7-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;" value="&lt;b&gt;Iniciativa:&amp;nbsp;&lt;/b&gt;Modernización de última milla y gestión de excepciones&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="40" width="310" x="890" y="130" as="geometry" />
        </mxCell>
        <mxCell id="U2_1jExU0mF8jxLVTO_7-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontColor=#FF8000;" value="&lt;span style=&quot;background-color: transparent;&quot;&gt;- Fortalecer la operación offline-first de la app de conductores.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;font style=&quot;color: rgb(0, 204, 0);&quot;&gt;- Implementar almacenamiento local cifrado y sincronización store-and-forward.&lt;/font&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: rgb(0, 204, 0);&quot;&gt;- Implementar persistencia local, confirmación en backend y reintentos automático para evitar pérdida de datos.&lt;/font&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Definir una taxonomía única de excepciones para app, TMS, CRM y portal.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Automatizar reintentos, devoluciones, reasignaciones y escalamiento de incidencias.&lt;/span&gt;" vertex="1">
          <mxGeometry height="180" width="330" x="880" y="180" as="geometry" />
        </mxCell>
        <mxCell id="U2_1jExU0mF8jxLVTO_7-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;" value="&lt;b&gt;Iniciativa:&amp;nbsp;&lt;/b&gt;Observabilidad, seguridad y gobierno multinube&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="40" width="310" x="510" y="400" as="geometry" />
        </mxCell>
        <mxCell id="U2_1jExU0mF8jxLVTO_7-10" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontColor=#FF8000;" value="&lt;span style=&quot;background-color: transparent;&quot;&gt;- Centralizar métricas, logs y trazas de Azure, AWS, GCP, SaaS y on-premises.&lt;/span&gt;&lt;br&gt;&lt;font style=&quot;color: rgb(0, 204, 0);&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Implementar tracking end-to-end mediante identificadores de correlación.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Crear tableros y alertas para colas, pedidos, inventario, rutas, entregas y SLA.&lt;/span&gt;&lt;/font&gt;&lt;br&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Implementar identidad federada, mínimo privilegio y gestión central de secretos.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Aplicar cifrado, auditoría, infraestructura como código y gobierno FinOps.&lt;/span&gt;&lt;h3&gt;&lt;/h3&gt;" vertex="1">
          <mxGeometry height="170" width="330" x="510" y="455" as="geometry" />
        </mxCell>
        <mxCell id="U2_1jExU0mF8jxLVTO_7-11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;" value="&lt;b&gt;Iniciativa:&amp;nbsp;&lt;/b&gt;Conciliación financiera y liquidación automatizada" vertex="1">
          <mxGeometry height="40" width="310" x="880" y="400" as="geometry" />
        </mxCell>
        <mxCell id="U2_1jExU0mF8jxLVTO_7-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontColor=#FF8000;" value="&lt;span style=&quot;background-color: transparent;&quot;&gt;- Integrar OMS, WMS, TMS, tracking, evidencias, portal y ERP.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Conciliar órdenes, estados, evidencias, SLA, tarifas y penalidades.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Automatizar el cálculo de bonificaciones, penalidades y notas de crédito.&lt;/span&gt;&lt;br&gt;&lt;font style=&quot;color: rgb(0, 204, 0);&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Implementar un motor de liquidación.&lt;/span&gt;&lt;br&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;- Reducir las conciliaciones manuales y el uso de hojas Excel.&lt;/span&gt;" vertex="1">
          <mxGeometry height="140" width="330" x="880" y="456.25" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
