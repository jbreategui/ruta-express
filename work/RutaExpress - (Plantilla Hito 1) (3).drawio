  <diagram id="fUpOK2kAOQ5olt0PNjaV" name="ADM - Preliminary">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="-E8mbdJhFviEpC8XbYul-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;ADM - Preliminary&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="290" x="610" y="20" as="geometry" />
        </mxCell>
        <mxCell id="2NFdy4n6s-tqJZpxpuOr-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;" value="&lt;div&gt;&lt;b&gt;UTEC Posgrado - Programa en Arquitectura de Soluciones Multinube&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Módulo: &lt;/b&gt;Fundamentos de Arquitectura Empresarial&lt;/div&gt;&lt;b&gt;Elaborado por: &lt;/b&gt;Grupo 6 — RutaExpress&lt;div&gt;&lt;b&gt;Fecha: &lt;/b&gt;Junio 2026&lt;/div&gt;" vertex="1">
          <mxGeometry height="75" width="407.75" x="30" y="600" as="geometry" />
        </mxCell>
        <mxCell id="wldSkU6bcbHR8Rxlyhe1-1" parent="1" style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=16;" value="&lt;b&gt;Modelo de Gobierno de Arquitectura:&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Garantizar una &lt;strong&gt;promesa de entrega confiable, medible y trazable&lt;/strong&gt; de extremo a extremo.&lt;/li&gt;&lt;li&gt;Priorizar una &lt;strong&gt;experiencia centrada en cliente y destinatario&lt;/strong&gt;, mejorando tiempos de respuesta y visibilidad.&lt;/li&gt;&lt;li&gt;Se usa &lt;b&gt;TOGAF ADM&lt;/b&gt; para documentar AS IS, TO BE, brechas, iniciativas y roadmap.&lt;/li&gt;&lt;li&gt;Diseñar una operación resiliente capaz de absorber campañas de alto volumen sin degradación crítica.&lt;/li&gt;&lt;li&gt;Arquitecto empresarial asignado al programa &lt;b&gt;RutaExpress Digital&lt;/b&gt;.&lt;/li&gt;&lt;li&gt;Artefactos en draw.io y repositorio compartido de arquitectura.&lt;/li&gt;&lt;li&gt;Control de decisiones: consolidar GCP en Azure, eliminar integraciones punto a punto y mantener WMS/ERP on-premises durante transicion.&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="360" width="470" x="20" y="80" as="geometry" />
        </mxCell>
        <mxCell id="wldSkU6bcbHR8Rxlyhe1-2" parent="1" style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=16;" value="&lt;b&gt;Principios o Lineamientos de Arquitectura:&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Principios de Arq. Negocio:&lt;/b&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Garantizar una &lt;strong&gt;promesa de entrega confiable, medible y trazable&lt;/strong&gt; de e2e.&amp;nbsp;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Priorizar una &lt;strong&gt;experiencia centrada en cliente y destinatario&lt;/strong&gt;, mejorando tiempos de respuesta y visibilidad.&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Diseñar una operación resiliente capaz de absorber campañas de alto volumen sin degradación crítica.&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;b&gt;Principios de Arq. Datos:&lt;/b&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Mantener una &lt;strong&gt;Single Source of Truth&lt;/strong&gt; para órdenes, inventario y tracking.&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Definir un &lt;strong&gt;modelo canónico de estados logísticos&lt;/strong&gt; para estandarizar toda la operación.&lt;/span&gt;&lt;/li&gt;&lt;li&gt;Garantizar trazabilidad completa entre:&lt;br&gt;&lt;strong&gt;Orden → Picking → Despacho → Entrega → Facturación&lt;/strong&gt;&lt;/li&gt;&lt;li&gt;Implementar sincronización de datos en tiempo real basada en eventos.&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="450" width="520" x="530" y="80" as="geometry" />
        </mxCell>
        <mxCell id="YZPttDq-ruwO6lZzcDED-1" parent="1" style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=16;" value="&lt;b&gt;Principios de Arq. Aplicaciones:&lt;/b&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Implementar un &lt;strong&gt;OMS (Order Management System)&lt;/strong&gt; como núcleo de orquestación central.&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Eliminar gradualmente integraciones punto a punto y adoptar un modelo &lt;strong&gt;API-first + Event-driven&lt;/strong&gt;.&lt;/span&gt;&lt;/li&gt;&lt;li&gt;Adoptar soluciones SaaS donde agreguen valor:&lt;ul data-spread=&quot;false&quot;&gt;&lt;li&gt;CRM&lt;/li&gt;&lt;li&gt;Portal clientes&lt;/li&gt;&lt;li&gt;Pasarela de pagos&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;Diseñar aplicaciones desacopladas por dominios:&lt;ul data-spread=&quot;false&quot;&gt;&lt;li&gt;Orders&lt;/li&gt;&lt;li&gt;Inventory&lt;/li&gt;&lt;li&gt;Dispatch&lt;/li&gt;&lt;li&gt;Delivery&lt;/li&gt;&lt;li&gt;Exceptions&lt;/li&gt;&lt;li&gt;Billing&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;/ul&gt;&lt;b style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); background-color: transparent;&quot;&gt;Principios de Arq. Tecnologica:&lt;/b&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Azure&lt;/strong&gt; será la nube principal para integración, APIs y orquestación logística.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;AWS&lt;/strong&gt; soportará la operación de última milla, almacenamiento de evidencias e IoT.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;GCP&lt;/strong&gt; se mantendrá como capa analítica y optimización predictiva.&lt;/li&gt;&lt;li&gt;Los sistemas legacy críticos (WMS/ERP) permanecerán on-premises bajo estrategia de transición progresiva hacia Cloud.&lt;/li&gt;&lt;li&gt;Toda solución deberá incorporar:&lt;ul data-spread=&quot;false&quot;&gt;&lt;li&gt;Security by Design&lt;/li&gt;&lt;li&gt;Observability by Design&lt;/li&gt;&lt;li&gt;Infrastructure as Code (IaC)&lt;/li&gt;&lt;li&gt;High Availability&lt;/li&gt;&lt;li&gt;FinOps Governance&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="660" width="520" x="1100" y="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="1PQQni45orLTPKzcR438" name="ADM - A. Architecture Vision">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="QpyEXKD8-lPZNFJSJTVt-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;ADM - A. Architecture Vision&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;b style=&quot;font-size: 16px; text-align: left;&quot;&gt;Cumplir Pedido Logistico Digital (orden-entrega-liquidacion)&lt;/b&gt;&lt;br style=&quot;font-size: 16px; text-align: left;&quot;&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="40" width="720" x="30" y="10" as="geometry" />
        </mxCell>
        <mxCell id="dutuvSDRXce6YuP2KaNS-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;" value="&lt;div&gt;&lt;b&gt;UTEC Posgrado - Programa en Arquitectura de Soluciones Multinube&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Módulo: &lt;/b&gt;Fundamentos de Arquitectura Empresarial&lt;/div&gt;&lt;b&gt;Elaborado por: &lt;/b&gt;Grupo 6 — RutaExpress&lt;div&gt;&lt;b&gt;Fecha: &lt;/b&gt;Junio 2026&lt;/div&gt;" vertex="1">
          <mxGeometry height="75" width="407.75" x="-740" y="825" as="geometry" />
        </mxCell>
        <mxCell id="SbNGJ-j7bjCgoqfWvqli-2" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Helvetica;fontSize=16;fontColor=default;align=left;verticalAlign=top;fontStyle=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 16px;&quot;&gt;Objetivo (TO- BE)&lt;/b&gt;&lt;/h1&gt;&lt;div&gt;&lt;ul style=&quot;margin-top:0cm&quot; type=&quot;disc&quot;&gt; &lt;li class=&quot;MsoNormal&quot;&gt;Transformar RutaExpress en una plataforma logística&amp;nbsp;digital, predictiva, escalable y resiliente.&lt;/li&gt;&lt;ul style=&quot;margin-top:0cm&quot; type=&quot;circle&quot;&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;Consolidar Azure como core logístico e&lt;br&gt;      integración, centralizando:&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;OMS (Order Management System)&amp;nbsp;&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;API Management&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;Event-driven orchestration&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;TMS&lt;/li&gt;&lt;/ul&gt; &lt;li class=&quot;MsoNormal&quot;&gt;Mantener AWS como plataforma para:&lt;/li&gt;&lt;ul style=&quot;margin-top:0cm&quot; type=&quot;circle&quot;&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;App móvil de conductores&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;Evidencias de entrega&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;IoT y sensores de temperatura&lt;/li&gt; &lt;/ul&gt;&lt;br&gt; &lt;li class=&quot;MsoNormal&quot;&gt;Mantener GCP como capa analítica especializada&amp;nbsp;para:&lt;/li&gt;&lt;ul style=&quot;margin-top:0cm&quot; type=&quot;circle&quot;&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;Optimización de rutas&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;Forecasting&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;Machine Learning&lt;/li&gt;&lt;/ul&gt; &lt;li class=&quot;MsoNormal&quot;&gt;Incorporar nuevas capacidades:&lt;/li&gt;&lt;ul style=&quot;margin-top:0cm&quot; type=&quot;circle&quot;&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;OMS centralizado.&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;Validación automática de órdenes.&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;Ingesta controlada CSV/Excel.&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;Gestión estandarizada de excepciones.&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;Conciliación automática de facturación.&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;Lakehouse para analítica integrada.&lt;/li&gt;&lt;/ul&gt; &lt;li class=&quot;MsoNormal&quot;&gt;Reducir dependencia de integraciones punto a punto mediante una arquitectura API-first + Event-driven.&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;b&gt;Alcance&lt;/b&gt;&lt;/p&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Procesos: &lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Recepción de&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;órdenes, preparación de pedidos, despacho, entrega, gestión de&amp;nbsp; excepciones, liquidación,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;devoluciones.&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;b&gt;Aplicaciones: &lt;/b&gt;OMS, WMS, TMS, App Conductores, Portal clientes, CRM, ERP, Repositorio de evidencias, Plataforma analítica.&lt;/li&gt;&lt;li&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Datos: &lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Órdenes, Inventario,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Tracking, Evidencias, Rutas, SLA, Facturación, Excepciones.&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Tecnología: &lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;APIs, Event&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Mesh, Observabilidad, Seguridad, IaC, FinOps.&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="821" width="660" x="-80" y="79" as="geometry" />
        </mxCell>
        <mxCell id="SbNGJ-j7bjCgoqfWvqli-5" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Helvetica;fontSize=16;fontColor=default;align=left;verticalAlign=top;fontStyle=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 16px;&quot;&gt;Situación Actual (AS-IS)&lt;/b&gt;&lt;/h1&gt;&lt;div&gt;&lt;ul style=&quot;margin-top:0cm&quot; type=&quot;disc&quot;&gt; &lt;li class=&quot;MsoNormal&quot;&gt;Arquitectura fragmentada compuesta por:&lt;/li&gt;&lt;ul style=&quot;margin-top:0cm&quot; type=&quot;circle&quot;&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;WMS on-premises como núcleo operativo de&amp;nbsp;almacenes.&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;TMS en Azure para gestión de transporte.&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;App de conductores en AWS con almacenamiento de&amp;nbsp;eventos y evidencias.&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;Analítica y optimización de rutas en GCP mediante&amp;nbsp;procesos batch.&lt;/li&gt;  &lt;li class=&quot;MsoNormal&quot;&gt;CRM y Portal de clientes SaaS.&lt;/li&gt;&lt;/ul&gt; &lt;li class=&quot;MsoNormal&quot;&gt;Existen múltiples integraciones punto a punto, generando dependencia alta y baja escalabilidad.&lt;/li&gt; &lt;li class=&quot;MsoNormal&quot;&gt;Se presentan problemas críticos:&lt;/li&gt; &lt;ul style=&quot;margin-top:0cm&quot; type=&quot;circle&quot;&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Pedidos duplicados.&lt;b&gt;&lt;/b&gt;&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Inventario desalineado entre centros.&lt;b&gt;&lt;/b&gt;&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Rutas ajustadas manualmente.&lt;b&gt;&lt;/b&gt;&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Tracking inconsistente.&lt;b&gt;&lt;/b&gt;&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Pérdida de evidencias de entrega.&lt;b&gt;&lt;/b&gt;&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Conciliación financiera lenta.&lt;b&gt;&lt;/b&gt;&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Durante campañas de alta demanda:&lt;b&gt;&lt;/b&gt;&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Hasta 180,000 pedidos diarios.&lt;b&gt;&lt;/b&gt;&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;6% de órdenes con defectos de datos.&lt;b&gt;&lt;/b&gt;&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Saturación del WMS y acumulación de pedidos.&lt;b&gt;&lt;/b&gt;&lt;/li&gt;&lt;/ul&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Indicadores críticos actuales:&lt;b&gt;&lt;/b&gt;&lt;/li&gt;&lt;ul style=&quot;margin-top:0cm&quot; type=&quot;circle&quot;&gt;&lt;li class=&quot;MsoNormal&quot;&gt;12.5% de entregas fallidas.&lt;b&gt;&lt;/b&gt;&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;17% de rutas modificadas manualmente.&lt;b&gt;&lt;/b&gt;&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;7% de servicios observados por diferencias de&lt;br&gt;      estado, tarifa o evidencia.&lt;/li&gt;&lt;/ul&gt;&lt;/ul&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Drivers&lt;/b&gt;&lt;br&gt;&lt;div&gt;&lt;div&gt;&lt;ul type=&quot;disc&quot; style=&quot;margin-top: 0cm;&quot;&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Reducción de tiempos de entrega por presión competitiva y crecimiento del e-commerce.&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Necesidad de trazabilidad end-to-end en tiempo real.&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Incremento de costos logísticos (combustible, reintentos y devoluciones).&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Necesidad de resiliencia operativa para campañas de alta demanda.&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Integración unificada de datos entre órdenes, inventario, transporte y facturación.&lt;/li&gt;&lt;li class=&quot;MsoNormal&quot;&gt;Reducción de conciliaciones manuales y mejora de flujo financiero.&lt;br&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="731" width="660" x="-740" y="79" as="geometry" />
        </mxCell>
        <mxCell id="MSH7fog3fxxAW35H6wCO-1" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Helvetica;fontSize=16;fontColor=default;align=left;verticalAlign=top;fontStyle=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 16px;&quot;&gt;KPI’s Estratégicos&lt;/b&gt;&lt;/h1&gt;&lt;div&gt;&lt;span id=&quot;docs-internal-guid-1c7c18f2-7fff-457a-17f0-b117218bfe72&quot;&gt;&lt;span style=&quot;font-size: 12pt; font-family: Aptos; background-color: transparent; font-variant: normal; vertical-align: baseline; white-space: pre-wrap;&quot;&gt;La transformación empresarial se tiene un tiempo estimado de 3 años por lo que se tiene los siguientes KPI&#39;s&lt;/span&gt;&lt;/span&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 16px;&quot;&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Cumplimiento de promesa: &lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;82% → 94% Mejorado mediante inventario sincronizado, OMS y automatización operativa.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/blockquote&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Entregas fallidas:&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;12.5% → 7% Reduciendo errores de dirección, ausencias y reintentos.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/blockquote&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Ciclo orden-despacho:&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;9.5h → 4h Eliminando batch y&amp;nbsp;mejorando sincronización en tiempo real.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/blockquote&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Tracking confiable:&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;82% → 98% Con persistencia resiliente y arquitectura orientada a eventos.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/blockquote&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Disponibilidad sistemas críticos:&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;96%-97% → 99.9% Implementando alta disponibilidad y resiliencia multicloud.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/blockquote&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Rutas modificadas manualmente:&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;17% → &amp;lt;5% Con optimización dinámica y datos en tiempo real.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/blockquote&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Facturación observada:&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;7% → &amp;lt;2%Mediante conciliación automática y trazabilidad completa.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/blockquote&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;Tiempo de conciliación&amp;nbsp;financiera:&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;&lt;blockquote style=&quot;margin: 0px 0px 0px 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 0px;&quot;&gt;&lt;div&gt;&lt;p class=&quot;MsoNormal&quot; style=&quot;line-height:normal&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;23 días → &amp;lt;3 días Consolidando información entre órdenes, entregas y facturación.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/blockquote&gt;&lt;div&gt;&lt;div&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;p&gt;&lt;/p&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="641" width="660" x="640" y="79" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
