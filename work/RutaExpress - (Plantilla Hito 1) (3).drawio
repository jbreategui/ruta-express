  <diagram id="22JL26coSIehDpM6RhhH" name="Arq. Neg. - Business Model Canvas">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bmc-bg" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;" value="" vertex="1">
          <mxGeometry height="890" width="1410" x="90" y="120" as="geometry" />
        </mxCell>
        <mxCell id="bmc-title" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 22px;&quot;&gt;&lt;b&gt;Business Model Canvas — RutaExpress&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="40" width="1350" x="120" y="150" as="geometry" />
        </mxCell>
        <mxCell id="bmc-b1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=14;" value="&lt;b&gt;Socios Clave&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;div&gt;&lt;div&gt;• Transportistas tercerizados (Olva, Shalom)&lt;/div&gt;&lt;div&gt;• Seguridad y custodia (Prosegur, Hermes)&lt;/div&gt;&lt;div&gt;• Entidad financiera para pago contra entrega (Niubiz, Izipay)&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="560" width="270" x="120" y="200" as="geometry" />
        </mxCell>
        <mxCell id="bmc-b2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=14;" value="&lt;b&gt;Actividades Clave&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Recepción y validación de órdenes&lt;br&gt;• Almacenamiento y preparación de pedidos&lt;br&gt;• Planificación de rutas y despacho&lt;br&gt;• Transporte y entrega de última milla&lt;br&gt;• Gestión de excepciones y logística inversa&lt;br&gt;• Liquidación, facturación y reportes" vertex="1">
          <mxGeometry height="280" width="270" x="390" y="200" as="geometry" />
        </mxCell>
        <mxCell id="bmc-b3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=14;" value="&lt;b&gt;Recursos Clave&lt;/b&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;• Red de 14 centros de distribución (físico)&lt;br&gt;• Flota de 2,700 vehículos, propia y refrigerada (físico)&lt;br&gt;• 9,500 colaboradores: conductores, pickers, planners (humano)&lt;br&gt;• Plataformas: WMS, TMS, app de conductores, optimizador, portales (tecnológico)&lt;br&gt;• Infraestructura multinube: Azure, AWS, GCP, on-premises (tecnológico)&lt;br&gt;• Datos logísticos: órdenes, inventario, rutas, tracking, evidencias (datos)&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="270" x="390" y="480" as="geometry" />
        </mxCell>
        <mxCell id="bmc-b4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=14;" value="&lt;b&gt;Propuesta de Valor&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Cobertura amplia&lt;br&gt;&lt;br&gt;• Velocidad y cumplimiento de promesa de entrega&lt;br&gt;&lt;br&gt;• Trazabilidad / visibilidad en vivo&lt;br&gt;&lt;br&gt;• Flexibilidad operativa&lt;br&gt;&lt;br&gt;• Capacidad de absorber picos de campaña&lt;br&gt;&lt;br&gt;• Fulfillment integral&lt;br&gt;&lt;br&gt;• Logística inversa y entregas refrigeradas" vertex="1">
          <mxGeometry height="560" width="270" x="660" y="200" as="geometry" />
        </mxCell>
        <mxCell id="bmc-b5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=14;" value="&lt;b&gt;Relación con Clientes&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Autoservicio digital por portal web y APIs&lt;br&gt;• Atención personalizada vía mesa / ejecutivo B2B&lt;br&gt;• Soporte y gestión de reclamos vía CRM" vertex="1">
          <mxGeometry height="280" width="270" x="930" y="200" as="geometry" />
        </mxCell>
        <mxCell id="bmc-b6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=14;" value="&lt;b&gt;Canales&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;div&gt;• APIs B2B (recepción de órdenes)&lt;/div&gt;&lt;div&gt;• APIs de trazabilidad (clientes grandes)&lt;/div&gt;&lt;div&gt;• Portal web SaaS de clientes (carga + tracking/reportes)&lt;/div&gt;&lt;div&gt;• Archivos CSV / Excel&lt;/div&gt;&lt;div&gt;• App de conductores&lt;/div&gt;&lt;div&gt;• CRM / centro de atención&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="270" x="930" y="480" as="geometry" />
        </mxCell>
        <mxCell id="bmc-b7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=14;" value="&lt;b&gt;Segmentos de Clientes&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;i&gt;Modelo B2B (alcance B2B2C)&lt;/i&gt;&lt;br&gt;&lt;br&gt;• Retailers / tiendas por departamento&lt;br&gt;• Marketplaces (e-commerce)&lt;br&gt;• Farmacéuticas y cadenas de farmacias&lt;br&gt;• Supermercados&lt;br&gt;• Consumo masivo (fabricantes CPG)&lt;br&gt;• Empresas de venta directa&lt;div&gt;&lt;br/&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="560" width="270" x="1200" y="200" as="geometry" />
        </mxCell>
        <mxCell id="bmc-b8" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=14;" value="&lt;b&gt;Estructura de Costos&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Combustible y energía&lt;br&gt;• Flota (mantenimiento, vehículos, tercerización)&lt;br&gt;• Mano de obra (9,500 colaboradores)&lt;br&gt;• Operación de centros de distribución (14 CDs)&lt;br&gt;• Tecnología multinube (Azure, AWS, GCP, SaaS, licencias)&lt;br&gt;• Penalidades por SLA y entregas fallidas / reintentos" vertex="1">
          <mxGeometry height="220" width="675" x="120" y="760" as="geometry" />
        </mxCell>
        <mxCell id="bmc-b9" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=14;" value="&lt;b&gt;Fuentes de Ingreso&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Contratos por volumen&lt;br&gt;• Tarifas por servicios de almacén (almacenamiento, picking, packing)&lt;br&gt;• Tarifas por transporte y entrega (última milla)&lt;br&gt;• Tarifas por logística inversa (devoluciones)&lt;br&gt;• Servicios premium (frío, alto valor, express)&lt;br&gt;• Bonificaciones por cumplimiento de SLA" vertex="1">
          <mxGeometry height="220" width="675" x="795" y="760" as="geometry" />
        </mxCell>
        <mxCell id="bmc-footer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;" value="&lt;div&gt;&lt;b&gt;UTEC Posgrado - Programa en Arquitectura de Soluciones Multinube&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Módulo: &lt;/b&gt;Fundamentos de Arquitectura Empresarial&lt;/div&gt;&lt;b&gt;Elaborado por: &lt;/b&gt;Grupo 6 — RutaExpress&lt;div&gt;&lt;b&gt;Fecha: &lt;/b&gt;Junio 2026&lt;/div&gt;" vertex="1">
          <mxGeometry height="75" width="407.75" x="120" y="1040" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
